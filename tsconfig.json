{
  "compilerOptions": {
    "sourceMap": true,
    "skipLibCheck": true,

    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedSideEffectImports": true,

    "types": ["node"],
    "target": "es2024",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "isolatedModules": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true
  }
}
